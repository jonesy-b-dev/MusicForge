@page
@model LoginModel
@{
}
<div class="loginContainer">
<h3> Login to MusicForge</h3>
<hr>
	<form method="post">
	  <div class="form-group">
		<label>Email address</label>
		<input type="email" class="form-control" asp-for="UserLoginModel.Email" id="exampleInputEmail1" aria-describedby="emailHelp">
		<span class="inputError" asp-validation-for="UserLoginModel.Email"></span>
	  </div>
	  <div class="form-group">
		<label>Password</label>
		<input type="password" class="form-control" asp-for="UserLoginModel.Password" id="exampleInputPassword1">
		<span class="inputError" asp-validation-for="UserLoginModel.Password"></span>
	  </div>
	<div style="display: flex; gap: 0.5rem;justify-content: center;">
		<button type="submit" class="btn btn-primary mt-2 mb-2">Login</button>
		<button type="submit" class="btn btn-primary mt-2 mb-2">
			<a class="nav-link text-dark" asp-area="" asp-page="/Register">Register</a>
		</button>
	</div>
	</form>
</div>
