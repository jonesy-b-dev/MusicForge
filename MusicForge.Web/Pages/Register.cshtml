@page
@model RegisterModel
@{
}
<div class="loginContainer">
<h3> Register to MusicForge</h3>
<hr>
	<form method="post" novalidate>
	  <div class="form-group">
		<label for="exampleInputEmail1">Email address</label>
		<input type="email" class="form-control" asp-for="UserRegisterModel.Email">
		<span class="inputError" asp-validation-for="UserRegisterModel.Email"></span>
	  </div>
	  <div class="form-group">
		<label for="exampleInputPassword1">First Name</label>
		<input type="text" class="form-control" asp-for="UserRegisterModel.FirstName">
		<span class="inputError" asp-validation-for="UserRegisterModel.FirstName"></span>
	  </div>
	  <div class="form-group">
		<label for="exampleInputPassword1">Last Name</label>
		<input type="text" class="form-control" asp-for="UserRegisterModel.LastName">
	  </div>
	  <div class="form-group">
		<label for="exampleInputPassword1">Password</label>
		<input type="password" class="form-control" asp-for="UserRegisterModel.Password">
		<span class="inputError" asp-validation-for="UserRegisterModel.Password"></span>
	  </div>
	  <div class="form-group">
		<label for="exampleInputPassword1">Repeat Password</label>
		<input type="password" class="form-control" asp-for="UserRegisterModel.PasswordRepeat">
		<span class="inputError" asp-validation-for="UserRegisterModel.PasswordRepeat"></span>
	  </div>
	  <div style="display: flex; justify-content: center;">
		  <button type="submit" class="btn btn-primary">Submit</button>
	  </div>
	</form>
</div>
