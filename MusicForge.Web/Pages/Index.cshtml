@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-title">
                <svg class="icon-lg" style="color: #F5B800;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
                <h1>Audio<span class="accent">Forge</span></h1>
            </div>

            <p class="hero-subtitle">
                Your premier destination for music industry insights, production techniques, and audio engineering excellence
            </p>

            <div class="hero-buttons">
                <a href="/articles" class="btn btn-primary">
                    <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                    Browse Articles
                </a>
                <button class="btn btn-secondary">
					<svg class="icon" fill="#FFFFFF" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path d="M 23.90625 3.96875 C 22.859375 3.96875 21.8125 4.375 21 5.1875 L 5.1875 21 L 5.125 21.3125 L 4.03125 26.8125 L 3.71875 28.28125 L 5.1875 27.96875 L 10.6875 26.875 L 11 26.8125 L 26.8125 11 C 28.4375 9.375 28.4375 6.8125 26.8125 5.1875 C 26 4.375 24.953125 3.96875 23.90625 3.96875 Z M 23.90625 5.875 C 24.410156 5.875 24.917969 6.105469 25.40625 6.59375 C 26.378906 7.566406 26.378906 8.621094 25.40625 9.59375 L 24.6875 10.28125 L 21.71875 7.3125 L 22.40625 6.59375 C 22.894531 6.105469 23.402344 5.875 23.90625 5.875 Z M 20.3125 8.71875 L 23.28125 11.6875 L 11.1875 23.78125 C 10.53125 22.5 9.5 21.46875 8.21875 20.8125 Z M 6.9375 22.4375 C 8.136719 22.921875 9.078125 23.863281 9.5625 25.0625 L 6.28125 25.71875 Z"/></svg>
                    Become a writer
                </button>
            </div>
        </div>
    </section>
	    <!-- Tools Section -->
    <section id="tools" class="tools-section">
        <div class="section-container">
            <div class="section-header">
                <h2 class="section-title">Learning tools</h2>
                <p class="section-subtitle">
                    Powerful tools to enhance your musical knowledge
                </p>
            </div>

            <div class="tools-grid">
                <!-- Tool 1: Chord Builder -->

                <a asp-page="/tools/chord-builder" class="navbar-link">
                <div class="tool-card">
                    <div class="tool-icon yellow">
                        <svg style="width: 2rem; height: 2rem; color: white;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" />
                        </svg>
                    </div>
                    <h3 class="tool-title">Chord Builder</h3>
                    <p class="tool-description">
						Analyze and learn chords
                    </p>
                </div>
				</a>

                <!-- Tool 2: Scale Builder-->
                <a asp-page="/tools/scale-builder" class="navbar-link">
                <div class="tool-card">
                    <div class="tool-icon green">
<svg style="width: 2rem; height: 2rem; color: white;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.8" d="M1 5h22M1 9h22M1 13h22M1 17h22M1 21h22"/>
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
</svg>
                    </div>
                    <h3 class="tool-title">Scale Builder</h3>
                    <p class="tool-description">
						Analyze build and learn scales
                    </p>
                </div>
				</a>

                <!-- Tool 3: Fretboard tool -->
                <a asp-page="/tools/chord-builder" class="navbar-link">
                <div class="tool-card">
                    <div class="tool-icon yellow">
